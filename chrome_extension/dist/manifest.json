{
  "manifest_version": 3,
  "name": "AI 消費決策層 Chrome 插件",
  "version": "1.0.0",
  "description": "在購物網站自動辨識結帳情境，推薦最划算的信用卡。",
  "action": {
    "default_title": "AI 消費決策層",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "tabs", "activeTab"],
  "host_permissions": [
    "https://shopee.tw/*",
    "https://*.shopee.tw/*",
    "https://www.momoshop.com.tw/*",
    "https://*.momoshop.com.tw/*",
    "https://24h.pchome.com.tw/*",
    "https://*.pchome.com.tw/*",
    "https://www.ubereats.com/*",
    "https://www.books.com.tw/*",
    "http://127.0.0.1:5500/*",
    "file:///*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://shopee.tw/*",
        "https://*.shopee.tw/*",
        "https://www.momoshop.com.tw/*",
        "https://*.momoshop.com.tw/*",
        "https://24h.pchome.com.tw/*",
        "https://*.pchome.com.tw/*",
        "https://www.ubereats.com/*",
        "https://www.books.com.tw/*",
        "http://127.0.0.1:5500/*",
        "file:///*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
